
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>share</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <section>
        <div class="s-outter-layer">
            <div class="s-inner-layer">

                <h1 class="share-header">Welcome!</h1>

                {% if modules is not empty %} <!--begin first if stmt-->
                    <ul>

                        {% for module in modules %} <!--begin first for loop-->
                            <li class="s-content">
                               <strong>{{ module.name }}</strong><br>
                                {{ module.description }}
                            </li>
                        {% endfor %} <!--end first for loop-->

                    </ul>
                {% else %}
                    <p>No modules completed yet.</p>
                {% endif %} <!--end first if stmt-->

            </div>
        </div>
    </section>
    
</body>
</html>